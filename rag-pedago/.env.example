# Nexus RAG Pedago local defaults.
# Copy to .env only for local development. Never commit real secrets.

APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=18001

DATA_DIR=./data
CONFIG_DIR=./configs
TAXONOMY_DIR=./taxonomy

QDRANT_URL=http://127.0.0.1:6333
