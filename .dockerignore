# Deny all by default.
**

# Keep this file visible to Docker.
!.dockerignore

# Required for Dockerfile.ingestor-v2.
!services/
!services/rag-engine/
!services/rag-engine/infra/
!services/rag-engine/infra/Dockerfile.ingestor-v2

# Required ingestor application and dependency files.
!services/rag-engine/src/
!services/rag-engine/src/ingestor/
!services/rag-engine/src/ingestor/**

# Required shared contracts package.
!packages/
!packages/contracts/
!packages/contracts/**

# Required for the UI image dependency smoke.
!scripts/
!scripts/e2e/
!scripts/e2e/smoke-ui-runtime-imports.sh

# Hard-deny sensitive and heavy files even if they appear under allowed paths.
.git
.git/**
**/.git
**/.git/**

.env
.env.*
**/.env
**/.env.*
**/*secret*
**/*secrets*
**/*credential*
**/*credentials*
**/creds
**/creds/**
**/private
**/private/**
**/*.pem
**/*.key
**/*.p12
**/*.pfx

**/node_modules
**/node_modules/**
**/.venv
**/.venv/**
**/venv
**/venv/**
**/__pycache__
**/__pycache__/**
**/.pytest_cache
**/.pytest_cache/**
**/.mypy_cache
**/.mypy_cache/**
**/.ruff_cache
**/.ruff_cache/**
**/.cache
**/.cache/**

**/data
**/data/**
**/uploads
**/uploads/**
**/volumes
**/volumes/**
**/backups
**/backups/**
**/backup
**/backup/**
**/corpus
**/corpus/**
**/artifacts
**/artifacts/**
**/dist
**/dist/**
**/build
**/build/**
