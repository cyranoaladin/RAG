# pgvector dédié RAG (ADR-0013, A-1)
# Copier en .env et remplir les valeurs avant démarrage.
PG_RAG_PASSWORD=
PG_RAG_PORT=5436

# Token separe pour les routes legacy /admin/*.
# Ne doit pas etre identique a INGESTOR_API_TOKEN / INGEST_AUTH_TOKEN.
LEGACY_ADMIN_API_TOKEN=

# Tokens v2 par role (valeurs a renseigner hors depot).
# Les roles distincts doivent avoir des valeurs de tokens distinctes.
# Les alias d'un meme role peuvent partager la meme valeur.
# Autorise: RAG_REVIEWER_TOKEN == REVIEWER_API_TOKEN.
# Compatibilite: INGESTOR_API_TOKEN et INGEST_AUTH_TOKEN restent des alias ingest_agent v2.
# Recommande: garder RAG_INGEST_AGENT_TOKEN distinct des tokens legacy d'ingestion.
# Interdit: RAG_ADMIN_TOKEN == RAG_STUDENT_TOKEN.
# Une collision entre roles distincts bloque security_v2 en fail-closed 503.
RAG_ADMIN_TOKEN=
RAG_REVIEWER_TOKEN=
REVIEWER_API_TOKEN=
RAG_TEACHER_TOKEN=
RAG_INGEST_AGENT_TOKEN=
INGESTOR_API_TOKEN=
INGEST_AUTH_TOKEN=
RAG_STUDENT_TOKEN=
INGESTOR_IP_ALLOWLIST=
INGESTOR_TRUSTED_PROXY_CIDRS=
